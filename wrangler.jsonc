{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "focuscat-web-demo",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "_worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "exclude": ["_worker.js"]
  },
  "observability": {
    "enabled": true
  }
}
